<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="@string/extracted_text_title"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#14000000">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/field_name"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/field_name_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textIsSelectable="true"
                    android:paddingBottom="4dp" />

                <RadioGroup
                    android:id="@+id/name_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/field_dosage"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:alpha="0.6"
                    android:paddingTop="8dp" />

                <TextView
                    android:id="@+id/field_dosage_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textIsSelectable="true"
                    android:paddingBottom="4dp" />

                <RadioGroup
                    android:id="@+id/dosage_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/field_cond"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:alpha="0.6"
                    android:paddingTop="8dp" />

                <TextView
                    android:id="@+id/field_cond_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textIsSelectable="true"
                    android:paddingBottom="4dp" />

                <RadioGroup
                    android:id="@+id/cond_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/field_forme"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:alpha="0.6"
                    android:paddingTop="8dp" />

                <TextView
                    android:id="@+id/field_forme_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textIsSelectable="true"
                    android:paddingBottom="4dp" />

                <RadioGroup
                    android:id="@+id/forme_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/field_ppa"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:alpha="0.6"
                    android:paddingTop="8dp" />

                <TextView
                    android:id="@+id/field_ppa_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textIsSelectable="true"
                    android:paddingBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/field_fab_date"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/field_fab_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textIsSelectable="true"
                    android:paddingBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/field_exp_date"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/field_exp_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textIsSelectable="true" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/raw_text_title"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:alpha="0.6"
                android:paddingTop="20dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/extracted_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:textIsSelectable="true" />

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/next_button" />

</LinearLayout>
